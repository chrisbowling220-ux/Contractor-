# Clerk publishable key (safe to expose in client-side builds by design).
# Loaded by Vite in all modes so `vite build` (the deployed builderspro.cc
# bundle) and local dev both pick it up. Vite only reads .env / .env.local /
# .env.[mode] — a stray name like ".env.local.save" is NOT loaded, which is
# what previously left the sign-in button dead.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_bm90ZWQtc2t1bmstMjEuY2xlcmsuYWNjb3VudHMuZGV2JA
