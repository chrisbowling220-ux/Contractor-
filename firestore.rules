rules_version = '2';

// Per-user isolation is enforced here using the Clerk→Firebase bridge:
// exchangeFirebaseToken (Cloud Function) mints a Firebase custom token whose
// uid == the Clerk user id, and the frontend signs in with it. So
// request.auth.uid == the Clerk user id, and it matches the `createdBy` field
// (and {userId} doc id) that all data is keyed by.
//
// Public share pages (estimate, invoice, change order, thank-you, photo log)
// are viewed by UNAUTHENTICATED customers, so specific collections allow public
// READ, and estimates/changeOrders allow a tightly-scoped public UPDATE so the
// customer can sign off (only the response fields — never totals/line items).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(resourceData) {
      return isSignedIn() && request.auth.uid == resourceData.createdBy;
    }
    // True if the incoming write changes ONLY the listed fields (plus none else).
    function onlyChanges(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── 2-YEAR LEGAL RETENTION LOCK ──
    // E-signed documents (and paid invoices) are the contractor's proof in a
    // dispute, so they CANNOT be deleted until 2 years after the signing/payment.
    // `anchorMs` is the epoch-ms the clock starts from (signedAtMs / paidAtMs).
    // 2 years = 730 days = 63,072,000,000 ms.
    function withinRetention(anchorMs) {
      return anchorMs is int && request.time.toMillis() < (anchorMs + 63072000000);
    }
    // A signed estimate/change order is locked while within retention.
    function signedDocLocked(d) {
      return ('signedAtMs' in d) && withinRetention(d.signedAtMs);
    }
    // A paid invoice is locked while within retention.
    function paidInvoiceLocked(d) {
      return ('paidAtMs' in d) && withinRetention(d.paidAtMs);
    }

    // ── users/{userId}: the owner's profile/tier. Public read so share pages
    //    can show business branding (name, logo, license). No public write. ──
    //
    // The client may ONLY write its own profile fields. Billing/entitlement
    // fields (tier, stripe*, subscriptionStatus, cancelAtPeriodEnd, aiQuotesUsed,
    // lastAiAt) are SERVER-ONLY — written exclusively by the Stripe webhook and
    // the AI-quota functions via the Admin SDK (which bypasses these rules).
    // This is an ALLOW-LIST: any field not listed here is rejected, so a client
    // can never grant itself Pro or reset its free-quote counter from the browser.
    // Allowed client-writable profile fields. Anything else (tier, stripe*,
    // subscriptionStatus, cancelAtPeriodEnd, aiQuotesUsed, lastAiAt, and the
    // Connect fields stripeConnectId / connectPayoutsEnabled / connectDetailsSubmitted)
    // is rejected — those are server-only, written via the Admin SDK / webhook.
    function isUserProfileKeys(keys) {
      return keys.hasOnly([
        'businessName', 'businessPhone', 'businessEmail', 'licenseNumber',
        'logoUrl', 'logoStoragePath', 'onboardedAt', 'updatedAt'
      ]);
    }
    match /users/{userId} {
      allow read: if true;
      // Create: the whole new doc may contain only profile fields.
      allow create: if isSignedIn() && request.auth.uid == userId
        && isUserProfileKeys(request.resource.data.keys());
      // Update: only profile fields may CHANGE; billing fields stay untouchable
      // (a merge write that doesn't alter them won't list them in affectedKeys).
      allow update: if isSignedIn() && request.auth.uid == userId
        && isUserProfileKeys(request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── estimates: owner full access. Public read (view shared estimate).
    //    Public update limited to the customer sign-off fields only. ──
    match /estimates/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      // Owner: full update. Anonymous customer may ONLY:
      //  - approve/decline (customerResponse + status + signedAtMs on approval), or
      //  - respond to the proposed start date (startDateResponse only).
      // Cannot touch amounts, totals, deposit, or forge other status values.
      allow update: if isOwner(resource.data)
        || (onlyChanges(['customerResponse', 'status', 'signedAtMs'])
            && request.resource.data.status in ['approved', 'declined'])
        // Customer may respond to the proposed start date ONCE — only if no
        // response exists yet. Prevents an anonymous actor overwriting a prior
        // confirmation. (Owner can always overwrite via the isOwner branch.)
        || (onlyChanges(['startDateResponse']) && !('startDateResponse' in resource.data));
      // Owner may delete UNLESS the document is e-signed and still within the
      // 2-year legal-retention window.
      allow delete: if isOwner(resource.data) && !signedDocLocked(resource.data);
    }

    // ── changeOrders: same pattern as estimates (incl. 2-year retention lock). ──
    match /changeOrders/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update: if isOwner(resource.data)
        || (onlyChanges(['customerResponse', 'status', 'signedAtMs'])
            && request.resource.data.status in ['approved', 'declined']);
      allow delete: if isOwner(resource.data) && !signedDocLocked(resource.data);
    }

    // ── invoices & thankYouPackages: public read (customer views/pays),
    //    owner-only create/update/delete. The Stripe webhook updates invoices
    //    via the Admin SDK, which bypasses these rules. ──
    match /invoices/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      // Owner can update anything. Anonymous customers can ONLY toggle the
      // cash-choice fields (so picking "Pay Cash" on the share page records
      // their intent). They cannot change amounts, line items, or status.
      allow update: if isOwner(resource.data)
        || onlyChanges(['customerCashChoice', 'customerCashAt']);
      // Owner may delete UNLESS this is a PAID invoice still within the 2-year
      // legal-retention window (proof of what was owed and that it was paid).
      allow delete: if isOwner(resource.data) && !paidInvoiceLocked(resource.data);
    }
    match /thankYouPackages/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }

    // ── customers: public read (photo-log share page needs the customer doc),
    //    owner-only writes. ──
    match /customers/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }

    // ── projects, customerPhotos, projectPhotos: owner-only across the board.
    //    Public pages don't read these directly (thank-you photos are snapshotted
    //    into the package doc), so no public access needed. ──
    match /projects/{id} {
      allow read: if isOwner(resource.data);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }
    // customerPhotos: PUBLIC read — the customer photo-log share page
    // (/log/{customerId}) is viewed by unauthenticated customers. Writes are
    // owner-only.
    match /customerPhotos/{id} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }
    match /projectPhotos/{id} {
      allow read: if isOwner(resource.data);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }

    // userMaterialPrices/{userId}: the contractor's own learned price book.
    // Doc id IS the user id — only that user can read/write it. (The generator
    // function reads it via the Admin SDK, which bypasses these rules.)
    match /userMaterialPrices/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // calendarEvents: the contractor's own calendar entries. Owner-only.
    match /calendarEvents/{id} {
      allow read: if isOwner(resource.data);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isOwner(resource.data);
    }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
